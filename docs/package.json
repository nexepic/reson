{
  "name": "nexdoc",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/docs && npm run dev",
    "build": "cd apps/docs && npm run build",
    "start": "cd apps/docs && npm run start",
    "lint": "cd apps/docs && npm run lint",
    "clean": "rm -rf apps/docs/.next apps/docs/.swc apps/docs/.content-collections apps/docs/tsconfig.tsbuildinfo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.0.0"
}
